<Window x:Class="View2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:View2.ViewModel"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:View2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="300">
    <Window.Resources>
        <vm:DoubleConverter x:Key="DoubleConverter" />
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0*"/>
            <ColumnDefinition Width="797*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Wartość 1" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="138,43,0,0" VerticalAlignment="Top" Width="63"/>
        <TextBox x:Name="TxtValue1" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="139,69,0,0" VerticalAlignment="Top"
                 Width="120" TextAlignment="Left" TextWrapping="NoWrap"
                 Text="{Binding Value1, Converter={StaticResource DoubleConverter}, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                 PreviewTextInput="Number_PreviewTextInput" DataObject.Pasting="Number_Pasting"/>
        <Label Content="Wartość 2" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,190,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TxtValue2" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="139,216,0,0" VerticalAlignment="Top"
                 Width="120" TextAlignment="Left" TextWrapping="NoWrap"
                 Text="{Binding Value2, Converter={StaticResource DoubleConverter}, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                 PreviewTextInput="Number_PreviewTextInput" DataObject.Pasting="Number_Pasting"/>
        <RadioButton Content="+" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,100,0,0" VerticalAlignment="Top"
                     IsChecked="{Binding IsAdd, Mode=TwoWay}" GroupName="Ops" />
        <RadioButton Content="-" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,120,0,0" VerticalAlignment="Top"
                     IsChecked="{Binding IsSubtract, Mode=TwoWay}" GroupName="Ops" />
        <RadioButton Content="*" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,140,0,0" VerticalAlignment="Top"
                     IsChecked="{Binding IsMultiply, Mode=TwoWay}" GroupName="Ops" />
        <RadioButton Content="/" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,162,0,0" VerticalAlignment="Top"
                     IsChecked="{Binding IsDivide, Mode=TwoWay}" GroupName="Ops" />
        <Label Content="Wynik" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,256,0,0" VerticalAlignment="Top"/>
        <TextBlock Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="139,282,0,0" TextWrapping="Wrap" VerticalAlignment="Top"
                   Text="{Binding Result}"/>
        <Button Content="Oblicz" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="136,237,0,0" VerticalAlignment="Top"
                Command="{Binding CalculateCommand}"/>

    </Grid>
</Window>
